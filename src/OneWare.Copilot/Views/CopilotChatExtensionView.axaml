<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:services="clr-namespace:OneWare.Copilot.Services"
             xmlns:views="clr-namespace:OneWare.Copilot.Views"
             xmlns:converters="clr-namespace:OneWare.Copilot.Converters"
             xmlns:behaviors="clr-namespace:OneWare.Essentials.Behaviors;assembly=OneWare.Essentials"
             xmlns:controls="clr-namespace:OneWare.Essentials.Controls;assembly=OneWare.Essentials"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="OneWare.Copilot.Views.CopilotChatExtensionView" x:DataType="services:CopilotChatService">
    <StackPanel Orientation="Horizontal" Spacing="4">

        <!-- Model selector -->
        <Button Name="MenuButton" VerticalAlignment="Center" Margin="0 0 0 0">
            <Button.Flyout>
                <Flyout FlyoutPresenterTheme="{StaticResource FlyoutNoPadding}"
                        Placement="TopEdgeAlignedRight">
                    <ListBox ItemsSource="{Binding Models}"
                             SelectedItem="{Binding SelectedModel}" BorderThickness="0"
                             MinWidth="200">
                        <Interaction.Behaviors>
                            <behaviors:PointerPressedHandledEventTrigger RoutingStrategies="Bubble">
                                <HideFlyoutAction Flyout="{Binding #MenuButton.Flyout}" />
                            </behaviors:PointerPressedHandledEventTrigger>
                        </Interaction.Behaviors>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="8"
                                      RowDefinitions="Auto, Auto" MinWidth="190"
                                      ToolTip.Tip="{Binding Converter={x:Static converters:ModelInfoTooltipConverter.Instance}}">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Name}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               Text="{Binding Capabilities.Limits.MaxContextWindowTokens, Converter={x:Static converters:TokenCountToCompactStringConverter.Instance}}"
                                               FontSize="11" VerticalAlignment="Center"
                                               HorizontalAlignment="Right"
                                               Foreground="{DynamicResource ThemeForegroundLowBrush}" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                               Text="{Binding Converter={x:Static converters:ModelPriceConverter.Instance}}"
                                               FontSize="10"
                                               Foreground="{DynamicResource ThemeForegroundLowBrush}"
                                               IsVisible="{Binding Billing.TokenPrices, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ListBox>
                </Flyout>
            </Button.Flyout>
            <StackPanel Orientation="Horizontal" Spacing="5">
                <TextBlock Text="{Binding SelectedModel.Name, FallbackValue=Select Model}"
                           FontSize="11" VerticalAlignment="Center"
                           Foreground="{DynamicResource ThemeForegroundLowBrush}" />
                <Image Source="{DynamicResource MaterialDesign.KeyboardArrowDown}" Width="8"
                       Height="8" />
            </StackPanel>
        </Button>

        <!-- Reasoning effort selector (only for models that support it) -->
        <Button Name="ReasoningButton" VerticalAlignment="Center"
                IsVisible="{Binding ShowReasoningEffort}"
                ToolTip.Tip="Reasoning effort">
            <Button.Flyout>
                <Flyout FlyoutPresenterTheme="{StaticResource FlyoutNoPadding}"
                        Placement="TopEdgeAlignedRight">
                    <ListBox ItemsSource="{Binding ReasoningEfforts}"
                             SelectedItem="{Binding SelectedReasoningEffort}" BorderThickness="0"
                             MinWidth="120">
                        <Interaction.Behaviors>
                            <behaviors:PointerPressedHandledEventTrigger RoutingStrategies="Bubble">
                                <HideFlyoutAction Flyout="{Binding #ReasoningButton.Flyout}" />
                            </behaviors:PointerPressedHandledEventTrigger>
                        </Interaction.Behaviors>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <TextBlock Text="{Binding}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ListBox>
                </Flyout>
            </Button.Flyout>
            <StackPanel Orientation="Horizontal" Spacing="5">
                <TextBlock Text="{Binding SelectedReasoningEffort, FallbackValue=effort}"
                           FontSize="11" VerticalAlignment="Center"
                           Foreground="{DynamicResource ThemeForegroundLowBrush}" />
                <Image Source="{DynamicResource MaterialDesign.KeyboardArrowDown}" Width="8"
                       Height="8" />
            </StackPanel>
        </Button>

    </StackPanel>
</UserControl>