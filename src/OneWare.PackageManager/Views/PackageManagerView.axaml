<controls:FlexibleWindow xmlns="https://github.com/avaloniaui"
                         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                         xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                         xmlns:viewModels="clr-namespace:OneWare.PackageManager.ViewModels"
                         xmlns:controls="clr-namespace:OneWare.Essentials.Controls;assembly=OneWare.Essentials"
                         PrefWidth="1050" PrefHeight="600"
                         mc:Ignorable="d"
                         x:Class="OneWare.PackageManager.Views.PackageManagerView"
                         CustomIcon="{DynamicResource PackageManager}"
                         Title="Extensions" Name="PackageManagerViewView"
                         x:CompileBindings="True" x:DataType="viewModels:PackageManagerViewModel"
                         WindowStartupLocation="CenterOwner">

    <controls:FlexibleWindow.Styles>
        <Style Selector="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="0 0 5 0" />
            <Setter Property="Margin" Value="0 5 5 5" />
        </Style>
    </controls:FlexibleWindow.Styles>

    <Border BorderThickness="0 1 0 0">
        <Grid RowDefinitions="Auto, *,Auto" ColumnDefinitions="180, Auto, *, Auto, *">

            <Border Grid.Column="0" Height="30" Grid.ColumnSpan="5" BorderThickness="0 0 0 1">
                <DockPanel LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left" Classes="ToolBar" Spacing="5" Margin="5"
                                HorizontalAlignment="Left">
                        <Button VerticalAlignment="Center" IsEnabled="{Binding !IsLoading}"
                                Command="{Binding RefreshPackagesAsync}">
                            <Image Height="16" Width="16" Source="{DynamicResource VsImageLib.RefreshGrey16X}" />
                        </Button>
                        <TextBlock Text="Show" />
                        <controls:SegmentedControl VerticalAlignment="Center"
                                                   SelectedIndex="{Binding SelectedFilterIndex, Mode=TwoWay}">
                            <controls:SegmentedControlItem Content="All" />
                            <controls:SegmentedControlItem Content="Installed" />
                            <controls:SegmentedControlItem Content="Available" />
                        </controls:SegmentedControl>

                    </StackPanel>

                    <StackPanel DockPanel.Dock="Right" Classes="ToolBar" Spacing="5" Margin="5"
                                HorizontalAlignment="Left">
                        <Button Classes="RoundButton" VerticalAlignment="Center" IsEnabled="{Binding !IsLoading}"
                                Command="{Binding UpdateAllAsync}" Padding="8 0">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <TextBlock Text="Update All" />
                                <Image Height="14" Width="14" Source="{DynamicResource VsImageLib.Download16X}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </DockPanel>
            </Border>
            <Border Grid.Column="0" Grid.Row="1" Grid.RowSpan="2" BorderThickness="0, 0, 1, 0"
                    Background="{DynamicResource ThemeControlLowBrush}">
                <TreeView Padding="3" BorderThickness="0" Background="Transparent"
                          ItemsSource="{Binding PackageCategories}" Name="TreeView" SelectionMode="Single"
                          SelectedItem="{Binding SelectedCategory, Mode=TwoWay}">
                    <TreeView.Styles>
                        <Style Selector="TreeViewItem" x:DataType="viewModels:PackageCategoryViewModel">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded}" />
                        </Style>
                    </TreeView.Styles>
                    <TreeView.DataTemplates>
                        <TreeDataTemplate DataType="viewModels:PackageCategoryViewModel"
                                          ItemsSource="{Binding SubCategories}">
                            <Grid ColumnDefinitions="Auto, Auto, *" Margin="2 5">
                                <Image
                                    IsVisible="{Binding IconModel, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    VerticalAlignment="Center" Width="18" HorizontalAlignment="Center"
                                    Source="{Binding IconModel.IconObservable^, FallbackValue={x:Null}}" />
                                <TextBlock Grid.Column="1" Margin="7 0" FontSize="13" Text="{Binding Header}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="2" Margin="3 0" HorizontalAlignment="Right"
                                           TextAlignment="Center" Text="{Binding VisiblePackages.Count}"
                                           Foreground="{DynamicResource ThemeBorderHighBrush}" />
                            </Grid>
                        </TreeDataTemplate>
                    </TreeView.DataTemplates>
                </TreeView>
            </Border>
            
            <GridSplitter Grid.Row="1" Grid.Column="1" Width="6" BorderThickness="0 0 1 0"
                          BorderBrush="{DynamicResource ThemeBorderLowBrush}"
                          Background="{DynamicResource ThemeBackgroundBrush}" HorizontalAlignment="Center" />

            <Grid Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                  Background="{DynamicResource ThemeBackgroundBrush}"
                  RowDefinitions="Auto,*" ColumnDefinitions="6,*">
                <Border Grid.Row="0" Grid.ColumnSpan="2" Padding="3" BorderThickness="0 0 0 1">
                    <Grid ColumnDefinitions="6,*">
                        <Border Grid.Column="1" Classes="RoundToolBar">
                            <controls:SearchBox SearchText="{Binding Filter}" SearchButtonVisible="False" />
                        </Border>
                    </Grid>
                </Border>
                <Grid Grid.Row="1" Grid.Column="1">
                    <ListBox Name="PluginList" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             Background="Transparent" BorderThickness="0"
                             SelectedItem="{Binding SelectedCategory.SelectedPackage, Mode=TwoWay, FallbackValue={x:Null}}"
                             ItemsSource="{Binding SelectedCategory.VisibleEntries, FallbackValue={x:Null}}">
                       <ListBox.ItemContainerTheme>
                           <ControlTheme TargetType="ListBoxItem"
                                         x:DataType="viewModels:PackageListEntryViewModel"
                                         BasedOn="{StaticResource {x:Type ListBoxItem}}">
                               <Setter Property="Focusable" Value="{Binding IsSelectable}" />
                               <Setter Property="IsHitTestVisible" Value="{Binding IsSelectable}" />
                               <Setter Property="IsTabStop" Value="{Binding IsSelectable}" />
                           </ControlTheme>
                       </ListBox.ItemContainerTheme>
                       <Interaction.Behaviors>
                           <EventTriggerBehavior EventName="SelectionChanged">
                              <InvokeCommandAction Command="{Binding ResolveSelectedPackageTabsAsync}" />
                            </EventTriggerBehavior>
                        </Interaction.Behaviors>
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.DataTemplates>
                            <DataTemplate DataType="viewModels:PackageSeparatorViewModel">
                                <Grid IsHitTestVisible="False"
                                      ColumnDefinitions="Auto,*"
                                      Margin="5 4 0 2">
                                    <TextBlock Text="{Binding Text}"
                                               Foreground="{DynamicResource ThemeForegroundLowBrush}" />
                                    <Border Grid.Column="1"
                                            IsVisible="{Binding ShowLine}"
                                            BorderThickness="0 1 0 0"
                                            BorderBrush="{DynamicResource ThemeBorderMidBrush}"
                                            Margin="8 0 0 0"
                                            VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                            <DataTemplate DataType="viewModels:PackageViewModel">
                                <DockPanel>
                                    <Grid DockPanel.Dock="Left" Width="60" Height="60">
                                        <Image
                                            VerticalAlignment="Center" HorizontalAlignment="Center"
                                            IsVisible="{Binding Image, Converter={x:Static ObjectConverters.IsNotNull}}"
                                            Source="{Binding Image}" Height="50" Width="50" />
                                        <controls:Spinner
                                            Height="30" Width="30" VerticalAlignment="Center"
                                            HorizontalAlignment="Center"
                                            IsVisible="{Binding Image, Converter={x:Static ObjectConverters.IsNull}}" />
                                    </Grid>
                                    <Grid DockPanel.Dock="Right" RowDefinitions="25, 25" Margin="10, 5, 0, 5"
                                          ColumnDefinitions="*, Auto">
                                        <TextBlock Grid.Column="0" Grid.Row="0" FontSize="15" FontWeight="Bold"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                   Text="{Binding PackageState.Package.Name}" />
                                        <TextBlock Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding PackageState.Package.Description}"
                                                   TextWrapping="Wrap" />
                                        <StackPanel Grid.Row="0" Grid.Column="1" Spacing="10" Orientation="Horizontal"
                                                    Margin="2 0 0 0">
                                            <Image Source="{DynamicResource VsImageLib.StatusWarning16X}"
                                                   Height="12"
                                                   IsVisible="{Binding PackageState.InstalledVersionWarningText, Converter={x:Static ObjectConverters.IsNotNull}}"
                                                   ToolTip.Tip="{Binding PackageState.InstalledVersionWarningText}" />
                                            <TextBlock
                                                Text="{Binding PackageState.InstalledVersion.Version, FallbackValue={}}"
                                                Foreground="{DynamicResource ThemeForegroundLowBrush}" />
                                            <Button Content="{Binding PrimaryButtonText}"
                                                    Name="MainButton"
                                                    Classes="RoundButton" Padding="8 3"
                                                    Background="{Binding PrimaryButtonBrush}"
                                                    Command="{Binding MainButtonCommand}">
                                                <Interaction.Behaviors>
                                                    <ButtonClickEventTriggerBehavior>
                                                        <ChangePropertyAction TargetObject="PluginList"
                                                                              PropertyName="SelectedItem"
                                                                              Value="{Binding}" />
                                                    </ButtonClickEventTriggerBehavior>
                                                </Interaction.Behaviors>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.DataTemplates>
                    </ListBox>
                    <controls:Spinner Height="20" VerticalAlignment="Center" HorizontalAlignment="Center"
                                      IsVisible="{Binding IsLoading}" />
                </Grid>
            </Grid>

            <GridSplitter Grid.Row="1" Grid.Column="3" Width="6" BorderThickness="1 0 0 0"
                          BorderBrush="{DynamicResource ThemeBorderLowBrush}"
                          Background="{DynamicResource ThemeBackgroundBrush}" HorizontalAlignment="Center" />

            <Border Grid.Row="1" Grid.Column="4" Padding="5">
                <ContentPresenter Content="{Binding #PluginList.SelectedItem}" />
            </Border>
        </Grid>
    </Border>

</controls:FlexibleWindow>
