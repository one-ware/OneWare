<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:settingTypes="clr-namespace:OneWare.Settings.ViewModels.SettingTypes"
             xmlns:controls="clr-namespace:OneWare.Essentials.Controls;assembly=OneWare.Essentials"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="OneWare.Settings.Views.SettingTypes.ComboListBoxSettingView"
             x:DataType="settingTypes:ComboListBoxSettingViewModel">
    <StackPanel Orientation="Vertical" Spacing="2">
        <StackPanel.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Restore Default" Command="{Binding RestoreDefaultCommand}" />
            </ContextMenu>
        </StackPanel.ContextMenu>
        <StackPanel Spacing="3" Orientation="Horizontal">
            <TextBlock Text="{Binding Setting.Title}"
                       ToolTip.Tip="{Binding Setting.HoverDescription}" />
            <Button Padding="0" VerticalAlignment="Center"
                    IsVisible="{Binding Setting.MarkdownDocumentation, Converter={x:Static ObjectConverters.IsNotNull}}">
                <Image Source="{DynamicResource BoxIcons.RegularHelpCircle}" Height="14" Width="14"
                       VerticalAlignment="Center" />
                <Button.Flyout>
                    <Flyout FlyoutPresenterTheme="{StaticResource FlyoutNoPadding}">
                        <controls:MarkdownViewer Markdown="{Binding Setting.MarkdownDocumentation}"
                                                 MaxWidth="900" MaxHeight="500" />
                    </Flyout>
                </Button.Flyout>
            </Button>
        </StackPanel>
        <Border Background="{DynamicResource ThemeControlMidBrush}" BorderThickness="1">
            <Grid RowDefinitions="20, *">
                <!-- Toolbar: predefined-options picker + action buttons -->
                <StackPanel Classes="ToolBar" Orientation="Horizontal">
                    <ComboBox ItemsSource="{Binding Setting.Options}"
                              SelectedItem="{Binding SelectedOption, Mode=TwoWay}"
                              IsEnabled="{Binding Setting.IsEnabledObservable^, FallbackValue={x:True}}"
                              MinWidth="80" MaxWidth="200"
                              Padding="4 0" Height="20" FontSize="12" />
                    <Button Command="{Binding AddSelected}"
                            IsEnabled="{Binding Setting.IsEnabledObservable^, FallbackValue={x:True}}"
                            ToolTip.Tip="Add selected option to list">
                        <Image Source="{DynamicResource BoxIcons.RegularPlus}" Height="12" />
                    </Button>
                    <Button Command="{Binding RemoveSelected}"
                            IsEnabled="{Binding Setting.IsEnabledObservable^, FallbackValue={x:True}}"
                            ToolTip.Tip="Remove selected item from list">
                        <Image Source="{DynamicResource MaterialDesign.Close}" Height="12" />
                    </Button>
                    <Button Command="{Binding MoveUp}"
                            IsEnabled="{Binding Setting.IsEnabledObservable^, FallbackValue={x:True}}"
                            ToolTip.Tip="Move selected item up">
                        <Image Source="{DynamicResource BoxIcons.RegularChevronUp}" Height="12" />
                    </Button>
                    <Button Command="{Binding MoveDown}"
                            IsEnabled="{Binding Setting.IsEnabledObservable^, FallbackValue={x:True}}"
                            ToolTip.Tip="Move selected item down">
                        <Image Source="{DynamicResource BoxIcons.RegularChevronDown}" Height="12" />
                    </Button>
                </StackPanel>
                <!-- The list of currently added steps -->
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding Setting.Items}"
                         SelectedIndex="{Binding SelectedListIndex, Mode=TwoWay}"
                         IsEnabled="{Binding Setting.IsEnabledObservable^, FallbackValue={x:True}}"
                         Height="100"
                         BorderBrush="{DynamicResource ThemeBorderLowBrush}"
                         BorderThickness="0 1 0 0" />
            </Grid>
        </Border>
    </StackPanel>
</UserControl>

