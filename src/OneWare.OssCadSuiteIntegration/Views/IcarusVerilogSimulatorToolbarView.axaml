<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:OneWare.OssCadSuiteIntegration.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="OneWare.OssCadSuiteIntegration.Views.IcarusVerilogSimulatorToolbarView"
             x:DataType="viewModels:IcarusVerilogSimulatorToolbarViewModel">
    <StackPanel DockPanel.Dock="Left" Classes="ToolBar">
        <TextBlock Text="IVerilog Arguments:" />
        <TextBox Width="200" Text="{Binding IcarusVerilogArguments}" />
        <TextBlock VerticalAlignment="Center" Text="Format"
                   ToolTip.Tip="Select the output format to use. VCD can be opened inside the IDE, while GHW and FST require GTKWave." />
        <Border Classes="RoundToolBar">
            <ComboBox Width="100" ItemsSource="{Binding AvailableWaveOutputFormats}" SelectedIndex="0"
                      SelectedItem="{Binding WaveOutputFormat, Mode=TwoWay}" />
        </Border>
    </StackPanel>
</UserControl>