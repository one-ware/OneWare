<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:OneWare.Chat.ViewModels"
             xmlns:controls="clr-namespace:OneWare.Essentials.Controls;assembly=OneWare.Essentials"
             xmlns:behaviors="clr-namespace:OneWare.Chat.Behaviors"
             xmlns:behaviors1="clr-namespace:OneWare.Essentials.Behaviors;assembly=OneWare.Essentials"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="OneWare.Chat.Views.ChatView" Name="ChatViewView"
             Background="{DynamicResource ThemeControlLowBrush}" x:DataType="viewModels:ChatViewModel">
    <Grid RowDefinitions="Auto, *, Auto, Auto, Auto" RowSpacing="4">
        <Border Background="{DynamicResource ThemeBackgroundBrush}"
                BorderThickness="0 0 0 1" Padding="4">
            <DockPanel LastChildFill="False">
                <StackPanel Spacing="8" Orientation="Horizontal" Margin="4">
                    <TextBlock Text="OneWare Chat" FontWeight="Bold" />
                    <TextBlock Text="{Binding StatusText}" FontSize="11" VerticalAlignment="Center"
                               Foreground="{DynamicResource ThemeForegroundLowBrush}" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            IsVisible="{Binding SelectedChatService, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <Button Command="{Binding InitializeCurrentCommand}"
                            IsVisible="{Binding !IsInitialized}">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <Image Source="{DynamicResource VsImageLib.RefreshGrey16X}" Height="8" Width="8"
                                   VerticalAlignment="Center" />
                            <TextBlock Text="Refresh" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NewChatCommand}" IsVisible="{Binding IsInitialized}">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <Image Source="{DynamicResource BoxIcons.RegularPlus}" Height="8" Width="8"
                                   VerticalAlignment="Center" />
                            <TextBlock Text="New Chat" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Name="HistoryButton"
                            IsVisible="{Binding !!SessionHistory.Count}">
                        <Button.Flyout>
                            <Flyout FlyoutPresenterTheme="{StaticResource FlyoutNoPadding}"
                                    Placement="BottomEdgeAlignedRight">
                                <ListBox ItemsSource="{Binding SessionHistory}"
                                         SelectedItem="{Binding SelectedSessionHistory}" BorderThickness="0"
                                         Width="300" MaxHeight="500">
                                    <Interaction.Behaviors>
                                        <behaviors1:PointerPressedHandledEventTrigger RoutingStrategies="Bubble">
                                            <HideFlyoutAction Flyout="{Binding #HistoryButton.Flyout}" />
                                        </behaviors1:PointerPressedHandledEventTrigger>
                                    </Interaction.Behaviors>
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="*, Auto, Auto" ColumnSpacing="6">
                                                <TextBlock Text="{Binding DisplayName}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="2" Text="{Binding UpdatedAtLabel}"
                                                           Foreground="{DynamicResource ThemeForegroundLowBrush}"
                                                           FontSize="11" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Flyout>
                        </Button.Flyout>
                        <Image Source="{DynamicResource Bootstrap.Clock}" Width="12" Height="12" />
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <Panel Grid.Row="1">
            <DockPanel>
                <!-- Loading indicator + queued messages are pinned below the conversation and kept
                     outside the scrolling region so the virtualizing message list above can virtualize
                     against the viewport (it must be the direct content of the ScrollViewer). -->
                <StackPanel DockPanel.Dock="Bottom" Margin="10 0 10 4" Spacing="5">
                    <!-- Loading Indicator -->
                    <Grid ColumnDefinitions="Auto, Auto" ColumnSpacing="5"
                          IsVisible="{Binding IsBusy}">
                        <controls:Spinner Width="12" Height="12" VerticalAlignment="Center" />

                        <TextBlock Grid.Column="1"
                                   Foreground="{DynamicResource ThemeForegroundLowBrush}" FontSize="11"
                                   FontStyle="Italic"
                                   Text="{Binding WorkingStatusText}" />
                    </Grid>

                    <!-- Queued messages (dimmed, pinned below the conversation) -->
                    <ItemsControl Opacity="0.5" ItemsSource="{Binding QueuedMessages}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Spacing="5" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </StackPanel>

                <ScrollViewer Name="ScrollViewer" HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <Interaction.Behaviors>
                        <AutoScrollDuringDragBehavior ScrollDelta="4" />
                    </Interaction.Behaviors>
                    
                    <ItemsControl Name="ItemsControl" ItemsSource="{Binding Messages}" Margin="10 0">
                        <ItemsControl.Styles>
                            <Style Selector="Expander /template/ ToggleButton">
                                <Setter Property="Background" Value="{DynamicResource ThemeAccentBrush4}" />
                                <Setter Property="CornerRadius" Value="3" />
                            </Style>
                            <Style Selector="Expander /template/ ToggleButton:pointerover /template/ Border">
                                <Setter Property="Background" Value="{DynamicResource ThemeAccentBrush4}" />
                            </Style>
                            <Style Selector="Expander /template/ ToggleButton:pointerover /template/ Border Border">
                                <Setter Property="Background" Value="Transparent" />
                            </Style>
                            <Style Selector="Expander /template/ ToggleButton#PART_toggle /template/ Border">
                                <Setter Property="CornerRadius" Value="3" />
                                <Setter Property="VerticalAlignment" Value="Center" />
                            </Style>
                            <Style Selector="Expander /template/ ToggleButton#PART_toggle /template/ Grid > Border">
                                <Setter Property="Margin" Value="0 2" />
                                <Setter Property="VerticalAlignment" Value="Center" />
                            </Style>
                        </ItemsControl.Styles>

                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <controls:EstimatingVirtualizingStackPanel Spacing="5"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>

            <!--
            <Border VerticalAlignment="Center" HorizontalAlignment="Center"
                    IsVisible="{Binding NeedsAuthentication}">
                <Button Command="{Binding AuthenticateCommand}" 
                        Background="{DynamicResource ThemeBackgroundBrush}"
                        Padding="5" Classes="RoundButton" Height="30">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock>
                            <Run Text="Login to " />
                            <Run Text="{Binding SelectedChatService.Name, FallbackValue={x:Null}}" />
                        </TextBlock>
                    </StackPanel>
                </Button>
            </Border>
            -->
        </Panel>

        <Border Grid.Row="2" Margin="10 4 10 0" Background="{DynamicResource ThemeControlMidBrush}"
                Classes="RoundBorder"
                IsVisible="{Binding !!AiFileEditService.ActiveEdits.Count}">
            <StackPanel Orientation="Vertical" Spacing="5">
                <Grid ColumnDefinitions="Auto, *, Auto">
                    <TextBlock Margin="4 0" VerticalAlignment="Center" Text="Changed Files"
                               Foreground="{DynamicResource ThemeForegroundLowBrush}" />
                    <Button Grid.Column="2" Command="{Binding AiFileEditService.UndoAllAsync}">
                        <TextBlock Text="Rollback" Foreground="{DynamicResource HighlightBrush}" />
                    </Button>
                </Grid>
                <ScrollViewer HorizontalScrollBarVisibility="Disabled" MaxHeight="100">
                    <ItemsControl ItemsSource="{Binding AiFileEditService.ActiveEdits}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button
                                    Command="{Binding #ChatViewView.((viewModels:ChatViewModel)DataContext).ShowEditCommand, FallbackValue={x:Null}}"
                                    CommandParameter="{Binding }" HorizontalContentAlignment="Stretch"
                                    HorizontalAlignment="Stretch" Background="Transparent">
                                    <Grid ColumnDefinitions="*, Auto, Auto" ColumnSpacing="5">
                                        <TextBlock Text="{Binding FileName}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="1" Text="{Binding AddedLines}" Foreground="Lime" />
                                        <TextBlock Grid.Column="2" Text="{Binding RemovedLines}" Foreground="OrangeRed" />
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Margin="10 0" Background="{DynamicResource ThemeControlMidBrush}"
                Classes="RoundBorder" BorderThickness="1"
                Classes.busy="{Binding IsBusy}">
            <Border.Styles>
                <Style Selector="Border.busy">
                    <Style.Animations>
                        <Animation Duration="0:0:1.6" IterationCount="INFINITE" PlaybackDirection="Alternate">
                            <KeyFrame Cue="0%">
                                <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderMidBrush}" />
                            </KeyFrame>
                            <KeyFrame Cue="100%">
                                <Setter Property="BorderBrush" Value="{DynamicResource ThemeAccentBrush}" />
                            </KeyFrame>
                        </Animation>
                    </Style.Animations>
                </Style>
            </Border.Styles>
            <Grid RowDefinitions="Auto, Auto, Auto, Auto">
                <ContentControl Grid.Row="0"
                                Content="{Binding SelectedChatService.TopUiExtension, FallbackValue={x:Null}}" />

                <TextBox Grid.Row="1" Classes="ToolBar" Name="CommandBox" Watermark="Type your task here..."
                         AcceptsReturn="True" TextWrapping="Wrap" MinHeight="50" MaxHeight="240"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         Padding="6 10 6 6" BorderThickness="0" Background="Transparent"
                         VerticalContentAlignment="Top" CaretBlinkInterval="00:00:00.5"
                         Text="{Binding CurrentMessage, Mode=TwoWay}" />

                <DockPanel Grid.Row="2" Height="22" Margin="4 4" LastChildFill="False" VerticalAlignment="Bottom">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Command="{Binding AbortCommand}" IsVisible="{Binding IsBusy}">
                            <Image Source="{DynamicResource VSImageLib2019.Stop_16x}" Height="16" />
                        </Button>
                        <Button Command="{Binding SendCommand}">
                            <Image Source="{DynamicResource FluentIcons.send_regular}" Height="16" />
                        </Button>
                        <Button Name="SendModeButton" VerticalAlignment="Center" IsEnabled="{Binding IsBusy}"
                                ToolTip.Tip="Message delivery">
                            <Button.Flyout>
                                <MenuFlyout>
                                    <MenuItem ToolTip.Tip="Stop and Send" Header="Send" InputGesture="Alt+Enter"
                                              Command="{Binding SendCommand}">
                                        <MenuItem.Icon>
                                            <Image Source="{DynamicResource FluentIcons.send_regular}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem ToolTip.Tip="Add to Queue" Header="Add to Queue"
                                              Command="{Binding QueueCommand}">
                                        <MenuItem.Icon>
                                            <Image Source="{DynamicResource BoxIcons.RegularPlus}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem ToolTip.Tip="Steer" Header="Steer with Message" InputGesture="Enter"
                                              Command="{Binding SteerCommand}" />
                                </MenuFlyout>
                            </Button.Flyout>
                            <Image Source="{DynamicResource MaterialDesign.KeyboardArrowDown}" Width="8" Height="8" />
                        </Button>
                    </StackPanel>

                    <ContentControl DockPanel.Dock="Left"
                                    Content="{Binding SelectedChatService.BottomUiExtension, FallbackValue={x:Null}}" />

                </DockPanel>
            </Grid>

        </Border>

        <!-- Footer row: chat service selection (left) + service-specific extension (right) -->
        <Border Grid.Row="4"
                BorderBrush="{DynamicResource ThemeBorderLowBrush}" Margin="10 0 10 4">
            <DockPanel LastChildFill="False" VerticalAlignment="Center">
                <Button Name="MenuButton" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <Button.Flyout>
                        <Flyout FlyoutPresenterTheme="{StaticResource FlyoutNoPadding}"
                                Placement="Top">
                            <ListBox ItemsSource="{Binding ChatServices}"
                                     SelectedItem="{Binding SelectedChatService}" BorderThickness="0"
                                     MinWidth="200">
                                <Interaction.Behaviors>
                                    <behaviors1:PointerPressedHandledEventTrigger RoutingStrategies="Bubble">
                                        <HideFlyoutAction Flyout="{Binding #MenuButton.Flyout}" />
                                    </behaviors1:PointerPressedHandledEventTrigger>
                                </Interaction.Behaviors>
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="*, Auto" ColumnSpacing="5">
                                            <TextBlock Text="{Binding Name}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ListBox>
                        </Flyout>
                    </Button.Flyout>
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock Text="{Binding SelectedChatService.Name, FallbackValue=Select Service}"
                                   FontSize="11" VerticalAlignment="Center"
                                   Foreground="{DynamicResource ThemeForegroundLowBrush}" />
                        <Image Source="{DynamicResource MaterialDesign.KeyboardArrowDown}" Width="8"
                               Height="8" />
                    </StackPanel>
                </Button>

                <ContentControl DockPanel.Dock="Right" VerticalAlignment="Center"
                                Content="{Binding SelectedChatService.FooterUiExtension, FallbackValue={x:Null}}" />
            </DockPanel>
        </Border>

    </Grid>
</UserControl>